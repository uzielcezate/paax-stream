# paax-stream environment variables
# Copy to .env for local development. Never commit .env.

# ── Source Platform (domain-agnostic) ─────────────────────────────────────────
# Base URL of the video source platform.  Never hardcode this.
SOURCE_PLATFORM_URL=https://www.youtube.com

# ── IPv6 Rotation ─────────────────────────────────────────────────────────────
# First address in the /124 IPv6 block assigned to your server.
IPV6_SUBNET_BASE=2604:A880:0004:01D0:0000:0002:7D72:C000
# Number of consecutive addresses in the pool (C000 … C00F = 16).
IPV6_POOL_SIZE=16

# ── Redis (session / cookie persistence) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# TTL for cached session cookies per IPv6 (seconds).  Default: 30 min.
SESSION_COOKIE_TTL=1800

# ── Streaming ─────────────────────────────────────────────────────────────────
# Chunk size for StreamingResponse (bytes).  Default: 64 KiB.
STREAM_CHUNK_SIZE=65536
# Timeout for upstream CDN requests (seconds).
UPSTREAM_TIMEOUT_S=15.0

# ── Invidious API (extraction backend) ────────────────────────────────────────
# Public Invidious instance used to resolve audio stream URLs.
# Change this if the current instance goes down.
# See: https://docs.invidious.io/instances/
INVIDIOUS_BASE_URL=https://yewtu.be

# ── HTTP client ───────────────────────────────────────────────────────────────
# Timeout for provider requests in milliseconds
REQUEST_TIMEOUT_MS=8000

# ── Cache (in-memory) ─────────────────────────────────────────────────────────
# TTL for cached stream resolutions in seconds (default: 10 minutes)
CACHE_TTL_SECONDS=600

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * to allow all (dev only).
# Example: FRONTEND_ORIGINS=https://paax.vercel.app,https://app.paax.io
FRONTEND_ORIGINS=*

# ── Server ────────────────────────────────────────────────────────────────────
# Railway injects PORT automatically. Locally defaults to 8080.
# PORT=8080   # uncomment to override locally

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
